# ═══════════════════════════════════════════════════════════════
# GBM Neoantigen Pipeline - Git Ignore File
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Data Files (Too large for GitHub)
# ─────────────────────────────────────────────────────────────────

# Raw TCGA data
GDCdata/
*.rds
# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ─────────────────────────────────────────────────────────────────
# Results (Generated by pipeline)
# ─────────────────────────────────────────────────────────────────

# Keep directory structure
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/netmhcpan_output/.gitkeep

# ─────────────────────────────────────────────────────────────────
# R and RStudio
# ─────────────────────────────────────────────────────────────────

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# RStudio files
.Rproj.user/
*.Rproj

# R Environment Variables
.Renviron
.Rprofile

# pkgdown site
docs/

# Translation temp files
po/*~

# ─────────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ─────────────────────────────────────────────────────────────────
# Windows
# ─────────────────────────────────────────────────────────────────

# Windows thumbnail cache files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────────
# Linux
# ─────────────────────────────────────────────────────────────────

*~

# temporary files which can be created if a process still has a handle open of a deleted file
.fuse_hidden*

# KDE directory preferences
.directory

# Linux trash folder
.Trash-*

# ─────────────────────────────────────────────────────────────────
# Python (if using Python scripts)
# ─────────────────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/

# ─────────────────────────────────────────────────────────────────
# Logs and Databases
# ─────────────────────────────────────────────────────────────────

*.log
*.sql
*.sqlite
*.db

# ─────────────────────────────────────────────────────────────────
# Compressed files
# ─────────────────────────────────────────────────────────────────

*.zip
*.tar.gz
*.rar
*.7z

# ─────────────────────────────────────────────────────────────────
# Temporary and backup files
# ─────────────────────────────────────────────────────────────────

*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────
# IDE files
# ─────────────────────────────────────────────────────────────────

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─────────────────────────────────────────────────────────────────
# Custom: NetMHCpan outputs (too large)
# ─────────────────────────────────────────────────────────────────

results/netmhcpan_output/predictions_*.txt
results/netmhcpan_output/peptides_*.txt

# ─────────────────────────────────────────────────────────────────
# Keep example outputs (small files for demonstration)
# ─────────────────────────────────────────────────────────────────

!results/example_output.csv
data/raw/TCGA_mutation_maf.csv
